@model Despliegue.Models.Event
@{ ViewData["Title"] = "Eliminar Evento"; }

<div class="row">
    <div class="col s12 m6 offset-m3">
        <div class="card" style="background:#1a1a2e;border-radius:12px">
            <div class="card-content center-align">
                <span class="card-title" style="color:#ef5350;font-family:'Bangers',cursive;font-size:2rem">
                    <i class="material-icons" style="vertical-align:middle">warning</i>
                    Eliminar Evento
                </span>
                <p style="color:#9e9e9e;margin:16px 0">¿Estás seguro que deseas eliminar este evento?</p>

                <div class="card" style="background:#12122a;border-radius:8px;text-align:left">
                    <div class="card-content">
                        @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                        {
                            <img src="@Model.ImagenUrl" alt="Póster"
                                 style="width:100%;max-height:200px;object-fit:cover;border-radius:6px;margin-bottom:12px"/>
                        }
                        <p><strong style="color:#e040fb">Nombre:</strong> @Model.Nombre</p>
                        <p><strong style="color:#e040fb">Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy")</p>
                        <p><strong style="color:#e040fb">Categoría:</strong> @Model.Categoria</p>
                        <p><strong style="color:#e040fb">Ubicación:</strong> @Model.Ubicacion</p>
                    </div>
                </div>
            </div>
            <div class="card-action center-align" style="background:#12122a;border-radius:0 0 12px 12px">
                <form asp-action="Delete" method="post">
                    <input name="id" type="hidden" value="@Model.Id"/>
                    <button type="submit" class="btn waves-effect waves-light red darken-3">
                        <i class="material-icons left">delete_forever</i>Sí, eliminar
                    </button>
                    <a href="/Events/Index" class="btn waves-effect waves-light grey darken-3"
                       style="margin-left:10px">
                        <i class="material-icons left">arrow_back</i>Cancelar
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>