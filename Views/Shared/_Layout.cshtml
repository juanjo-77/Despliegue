<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — AniEvents</title>

    <!-- Materialize CSS -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css"/>
    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Nunito:wght@400;600;700&display=swap"
          rel="stylesheet"/>

    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #0d0d1a; color: #e0e0e0; }
        nav { background: linear-gradient(90deg, #1a0033, #3d0066); }
        nav .brand-logo { font-family: 'Bangers', cursive; font-size: 2rem; letter-spacing: 2px; color: #e040fb; }
        nav ul a { color: #e0e0e0; font-weight: 600; }
        nav ul a:hover { color: #e040fb; background: transparent; }
        footer { background-color: #1a0033; color: #9e9e9e; padding: 20px 0; text-align: center; }
        .page-content { min-height: calc(100vh - 130px); padding: 30px 0; }
        .alert-success { background-color: #1b5e20; color: #fff; padding: 12px 20px;
                         border-radius: 6px; margin-bottom: 16px; }
    </style>
</head>
<body>
    <nav>
        <div class="nav-wrapper container">
            <a href="/Events/Gallery" class="brand-logo">
                <i class="material-icons" style="vertical-align:middle;color:#e040fb">auto_awesome</i>
                AniEvents
            </a>
            <ul id="nav-mobile" class="right hide-on-med-and-down">
                <li><a href="/Events/Gallery"><i class="material-icons left">collections</i>Galería</a></li>
                <li><a href="/Events/Index"><i class="material-icons left">admin_panel_settings</i>Admin</a></li>
            </ul>
        </div>
    </nav>

    <div class="page-content">
        <div class="container">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert-success">
                    <i class="material-icons" style="vertical-align:middle">check_circle</i>
                    @TempData["Mensaje"]
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <footer>
        <p>AniEvents &copy; @DateTime.Now.Year — Tu cartelera de eventos anime</p>
    </footer>

    <!-- Materialize JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>document.addEventListener('DOMContentLoaded', () => M.AutoInit());</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>